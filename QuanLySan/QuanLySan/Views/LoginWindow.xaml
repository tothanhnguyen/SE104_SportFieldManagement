<Window
        x:Class="QuanLySan.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Đăng nhập"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2A4B8C"/>

        <Style x:Key="RoundedInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="5" Background="White" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A BooleanToVisibilityConverter is needed to hide/show Register fields -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Background -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="10,10,0,0">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <fa:IconBlock Icon="Dribbble" FontSize="48" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="PHẦN MỀM QUẢN LÝ SÂN THỂ THAO" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <!-- Close button -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                            Background="Transparent" BorderThickness="0" Foreground="White" Cursor="Hand" Click="BtnClose_Click">
                        <fa:IconBlock Icon="Xmark" FontSize="20"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Form Area -->
            <StackPanel Grid.Row="1" Margin="40,30,40,30">
                <!-- Titles -->
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Đăng nhập hệ thống" FontSize="24" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"
                               Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="Đăng ký tài khoản" FontSize="24" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"
                               Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Text="Tên đăng nhập" Foreground="#555555" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RoundedInput}" Margin="0,0,0,15"/>

                <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Email" Foreground="#555555" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource RoundedInput}" Margin="0,0,0,15"/>
                </StackPanel>

                <TextBlock Text="Mật khẩu" Foreground="#555555" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,25">
                    <PasswordBox x:Name="txtPassword" PasswordChanged="txtPassword_PasswordChanged" 
                                 Height="40" Padding="10,0" FontSize="14" VerticalContentAlignment="Center" 
                                 BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
                        <PasswordBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>
                    <TextBox x:Name="txtPasswordVisible" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource RoundedInput}" Visibility="Collapsed" />
                    <ToggleButton x:Name="btnRevealPassword" Width="30" Height="30" HorizontalAlignment="Right" Margin="0,0,5,0" 
                                  Background="Transparent" BorderThickness="0" Cursor="Hand" Checked="btnRevealPassword_Checked" Unchecked="btnRevealPassword_Unchecked">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                    <fa:IconBlock x:Name="icon" Icon="Eye" Foreground="#999999" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="icon" Property="Icon" Value="EyeSlash"/>
                                        <Setter TargetName="icon" Property="Foreground" Value="#3B82F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </Grid>

                <!-- Main Action Button -->
                <Button Command="{Binding SubmitCommand}" Background="{StaticResource PrimaryBrush}" Foreground="White" 
                        Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="scaleTrans" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Hover Effect -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="border" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25" Color="#1B2A4A"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <!-- Pressed Effect -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#111B30"/>
                                    <Setter TargetName="border" Property="Effect" Value="{x:Null}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scaleTrans" Storyboard.TargetProperty="ScaleX" To="0.96" Duration="0:0:0.05" />
                                                <DoubleAnimation Storyboard.TargetName="scaleTrans" Storyboard.TargetProperty="ScaleY" To="0.96" Duration="0:0:0.05" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="scaleTrans" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="scaleTrans" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CircleEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="Đăng ký"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                    <Setter Property="Content" Value="Đăng nhập"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Toggle Action -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Foreground="#777777">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Đã có tài khoản? "/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                        <Setter Property="Text" Value="Chưa có tài khoản? "/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Command="{Binding ToggleModeCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Đăng nhập ngay"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoginMode}" Value="True">
                                            <Setter Property="Text" Value="Đăng ký tài khoản mới"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#111B30"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
