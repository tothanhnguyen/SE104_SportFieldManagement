<Window x:Class="QuanLySan.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý sân thể thao" Height="500" Width="780"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Nút menu trong sidebar -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="20,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27406B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── SIDEBAR ── -->
        <Border Grid.Column="0" Background="#1B2B49">
            <StackPanel>
                <TextBlock Text="QUẢN LÝ SÂN" Foreground="White" FontSize="18" FontWeight="Bold"
                           Margin="20,24,20,4"/>
                <TextBlock Text="Thể thao" Foreground="#9FB3D1" FontSize="13" Margin="20,0,20,18"/>
                <Border Height="1" Background="#2E4A6B" Margin="0,0,0,8"/>

                <Button Content="Tiếp nhận sân" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="TiepNhanSan"/>
                <Button Content="Đăng ký hội viên" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="DangKyHoiVien"/>
                <Button Content="Tra cứu hội viên" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="TraCuuHoiVien"/>
                <Button Content="Đặt sân" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="DatSan"/>
                <Button Content="Thanh toán đặt sân" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="ThanhToan"/>
                <Button Content="Báo cáo DT theo sân" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="BaoCaoSan"/>
                <Button Content="Báo cáo DT theo khách hàng" Style="{StaticResource MenuButton}"
                        Command="{Binding MoBieuMauCommand}" CommandParameter="BaoCaoKhachHang"/>
            </StackPanel>
        </Border>

        <!-- ── VÙNG NỘI DUNG ── -->
        <Grid Grid.Column="1" Background="#F4F6F9">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="PHẦN MỀM QUẢN LÝ SÂN THỂ THAO"
                           FontSize="22" FontWeight="Bold" Foreground="#1B2B49"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Chọn chức năng ở menu bên trái để bắt đầu."
                           FontSize="14" Foreground="#555" Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
