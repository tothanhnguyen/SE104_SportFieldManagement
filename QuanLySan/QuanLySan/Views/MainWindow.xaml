<Window x:Class="QuanLySan.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Quản lý sân thể thao" Height="680" Width="1080"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        MinWidth="900" MinHeight="600"
        Background="#F0F2F5">

    <Window.Resources>
        <!-- ═══ BẢNG MÀU ═══ -->
        <SolidColorBrush x:Key="SidebarBg"     Color="#1B2B49"/>
        <SolidColorBrush x:Key="SidebarHover"   Color="#27406B"/>
        <SolidColorBrush x:Key="AccentBlue"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentGreen"    Color="#10B981"/>
        <SolidColorBrush x:Key="AccentOrange"   Color="#F59E0B"/>
        <SolidColorBrush x:Key="AccentPurple"   Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentRed"      Color="#EF4444"/>
        <SolidColorBrush x:Key="CardBg"         Color="White"/>
        <SolidColorBrush x:Key="PageBg"         Color="#F0F2F5"/>
        <SolidColorBrush x:Key="TextDark"       Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMuted"      Color="#64748B"/>
        <SolidColorBrush x:Key="BorderLight"    Color="#E2E8F0"/>

        <!-- ═══ NÚT MENU SIDEBAR ═══ -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="8,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                Padding="18,0" CornerRadius="8">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#27406B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ NÚT HÀNH ĐỘNG NHỎ (Sửa, Xóa) ═══ -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="4,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ DATAGRID STYLE ═══ -->
        <Style x:Key="DashboardGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="IsReadOnly" Value="False"/>
        </Style>

        <Style x:Key="DashboardGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- ═══ NÚT REFRESH ═══ -->
        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  SIDEBAR                                                  -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>
                <!-- ── Profile Section (trên cùng) ── -->
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,0">
                    <!-- Avatar hình tròn -->
                    <Border Width="72" Height="72" CornerRadius="36" 
                            Background="#334C73" HorizontalAlignment="Center"
                            BorderBrush="#4A6FA5" BorderThickness="2.5">
                        <fa:IconImage Icon="UserTie" Width="36" Height="36" Foreground="White" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Quản trị viên" Foreground="White" FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,10,0,2"/>
                    <TextBlock Text="admin@quanlisan.vn" Foreground="#8BA3C4" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <!-- Badge trạng thái online -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,20">
                        <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Đang hoạt động" Foreground="#6EE7B7" FontSize="11"/>
                    </StackPanel>
                    <Border Height="1" Background="#2E4A6B" Margin="16,0,16,8"/>
                </StackPanel>

                <!-- ── Menu navigation ── -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,4,0,20">
                        <TextBlock Text="QUẢN LÝ" Foreground="#6B87AD" FontSize="10" FontWeight="Bold"
                                   Margin="24,8,0,6"/>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="TiepNhanSan">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="ClipboardList" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tiếp nhận sân" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="DangKyHoiVien">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="UserPlus" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Đăng ký hội viên" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="TraCuuHoiVien">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="MagnifyingGlass" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tra cứu hội viên" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="#2E4A6B" Margin="16,10,16,6"/>

                        <TextBlock Text="ĐẶT SÂN" Foreground="#6B87AD" FontSize="10" FontWeight="Bold"
                                   Margin="24,8,0,6"/>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="DatSan">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="CalendarPlus" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Đặt sân" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="ThanhToan">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="CreditCard" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Thanh toán đặt sân" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="#2E4A6B" Margin="16,10,16,6"/>

                        <TextBlock Text="BÁO CÁO" Foreground="#6B87AD" FontSize="10" FontWeight="Bold"
                                   Margin="24,8,0,6"/>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="BaoCaoSan">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="ChartColumn" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="DT theo sân" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MenuButton}" Command="{Binding MoBieuMauCommand}" CommandParameter="BaoCaoKhachHang">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="ChartLine" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="DT theo khách hàng" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!--  VÙNG NỘI DUNG CHÍNH (Dashboard)                         -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="{StaticResource PageBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── TOP BAR ── -->
            <Border Grid.Row="0" Background="White" Padding="24,14" 
                    BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <fa:IconImage Icon="Futbol" Width="26" Height="26" Foreground="{StaticResource AccentBlue}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tổng quan hệ thống" FontSize="18" FontWeight="Bold" 
                                       Foreground="{StaticResource TextDark}"/>
                            <TextBlock Text="{Binding NgayGioHienTai}" FontSize="12" 
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource RefreshButton}" Command="{Binding RefreshCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="RotateRight" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Làm mới" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── SCROLLABLE CONTENT ── -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18,24,24">
                <StackPanel>

                    <!-- ═══════════ HÀNG 1: BẢNG DANH SÁCH SÂN ═══════════ -->
                    <Border Background="White" CornerRadius="12" Padding="20,16" Margin="0,0,0,18"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Tiêu đề -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <fa:IconBlock Icon="ListUl" Foreground="{StaticResource TextDark}" FontSize="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Danh sách sân" FontSize="15" FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Công cụ (Tìm kiếm, Lọc, Thêm mới) -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <!-- Ô Tìm kiếm -->
                                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Background="#F8FAFC" Padding="8,0" Margin="0,0,8,0" Width="140" Height="32">
                                        <Grid>
                                            <fa:IconBlock Icon="MagnifyingGlass" Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="Transparent" BorderThickness="0" Margin="20,0,0,0" VerticalAlignment="Center"
                                                     Foreground="#334155" FontSize="12" />
                                            <TextBlock Text="Tìm sân..." Foreground="#94A3B8" FontSize="12" Margin="22,0,0,0" VerticalAlignment="Center"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Lọc theo Loại sân -->
                                    <ComboBox ItemsSource="{Binding DsLoaiSanFilter}" SelectedItem="{Binding SelectedLoaiSan}"
                                              Width="110" Height="32" Margin="0,0,8,0" VerticalContentAlignment="Center"
                                              Background="White" BorderBrush="#E2E8F0" FontSize="12"/>

                                    <!-- Lọc theo Tình trạng -->
                                    <ComboBox ItemsSource="{Binding DsTinhTrangFilter}" SelectedItem="{Binding SelectedTinhTrang}"
                                              Width="120" Height="32" Margin="0,0,12,0" VerticalContentAlignment="Center"
                                              Background="White" BorderBrush="#E2E8F0" FontSize="12"/>

                                    <!-- Nút Thêm mới -->
                                    <Button Style="{StaticResource RefreshButton}" Background="#10B981" Height="32" Padding="10,0"
                                            Command="{Binding MoBieuMauCommand}" CommandParameter="TiepNhanSan">
                                        <StackPanel Orientation="Horizontal">
                                            <fa:IconBlock Icon="Plus" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Thêm sân" VerticalAlignment="Center" FontSize="12"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <DataGrid x:Name="dgSan"
                                      ItemsSource="{Binding DsSanHienThi}"
                                      SelectedItem="{Binding SanSelected}"
                                      Style="{StaticResource DashboardGrid}"
                                      ColumnHeaderStyle="{StaticResource DashboardGridHeader}"
                                      MaxHeight="400"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Mã sân" Binding="{Binding MaSan}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#1E293B"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Tên sân" Binding="{Binding TenSan, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="1.4*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Loại sân" Binding="{Binding TenLoaiSan}" Width="1.2*" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="1.8*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Foreground" Value="#64748B"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.EditingElementStyle>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </DataGridTextColumn.EditingElementStyle>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn Header="Khung giờ" Binding="{Binding SoKhungGio}" Width="76" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Padding" Value="12,0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#3B82F6"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Cột Trạng thái -->
                                    <DataGridTemplateColumn Header="Trạng thái" Width="100" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8,3" HorizontalAlignment="Left"
                                                        VerticalAlignment="Center" Margin="8,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHoatDong}" Value="True">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding TenTinhTrang}" FontSize="11" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#D97706"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsHoatDong}" Value="True">
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Cột hành động: Sửa / Xóa -->
                                    <DataGridTemplateColumn Header="Thao tác" Width="90" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Button ToolTip="Lưu thay đổi"
                                                            Style="{StaticResource ActionButton}" Background="#EFF6FF"
                                                            Command="{Binding DataContext.SuaSanCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <fa:IconBlock Icon="PenToSquare" Foreground="#3B82F6" FontSize="12"/>
                                                    </Button>
                                                    <Button ToolTip="Xóa sân" Margin="4,0,0,0"
                                                            Style="{StaticResource ActionButton}" Background="#FEF2F2"
                                                            Command="{Binding DataContext.XoaSanCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}">
                                                        <fa:IconBlock Icon="Trash" Foreground="#EF4444" FontSize="12"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- ── THANH PHÂN TRANG ── -->
                            <Grid Margin="0,12,0,0">
                                <!-- Thông tin phân trang (Bên trái) -->
                                <TextBlock VerticalAlignment="Center" Foreground="#64748B" FontSize="12">
                                    <Run Text="Hiển thị trang "/>
                                    <Run Text="{Binding CurrentPage}" FontWeight="Bold" Foreground="#1E293B"/>
                                    <Run Text=" / "/>
                                    <Run Text="{Binding TotalPages}" FontWeight="Bold" Foreground="#1E293B"/>
                                    <Run Text=" (Tổng "/>
                                    <Run Text="{Binding TotalFiltered}" FontWeight="Bold" Foreground="#3B82F6"/>
                                    <Run Text=" sân)"/>
                                </TextBlock>

                                <!-- Nút chuyển trang (Bên phải) -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding PrevPageCommand}" Width="32" Height="32" 
                                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1" 
                                            Margin="0,0,6,0" Cursor="Hand" ToolTip="Trang trước">
                                        <fa:IconBlock Icon="ChevronLeft" FontSize="12" Foreground="#475569"/>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Command="{Binding NextPageCommand}" Width="32" Height="32" 
                                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1" 
                                            Cursor="Hand" ToolTip="Trang sau">
                                        <fa:IconBlock Icon="ChevronRight" FontSize="12" Foreground="#475569"/>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>


                    <!-- ═══════════ HÀNG 2: THỐNG KÊ CARDS ═══════════ -->
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,18">
                        <!-- Card: Tổng sân -->
                        <Border Background="White" CornerRadius="12" Padding="18,16" Margin="0,0,10,0"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Tổng số sân" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding TongSan}" FontSize="28" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextDark}"/>
                                        <TextBlock Text=" sân" FontSize="14" Foreground="{StaticResource TextMuted}" 
                                                   VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Border Background="#DCFCE7" CornerRadius="4" Padding="5,2">
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconBlock Icon="CircleCheck" Foreground="#16A34A" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock FontSize="11" Foreground="#16A34A" VerticalAlignment="Center">
                                                    <Run Text="{Binding SanHoatDong, Mode=OneWay}"/>
                                                    <Run Text=" hoạt động"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FEF3C7" CornerRadius="4" Padding="5,2" Margin="6,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <fa:IconBlock Icon="Wrench" Foreground="#D97706" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock FontSize="11" Foreground="#D97706" VerticalAlignment="Center">
                                                    <Run Text="{Binding SanBaoTri, Mode=OneWay}"/>
                                                    <Run Text=" bảo trì"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Border Width="44" Height="44" CornerRadius="10" Background="#EFF6FF"
                                        HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <fa:IconImage Icon="Map" Width="22" Height="22" Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Card: Hội viên -->
                        <Border Background="White" CornerRadius="12" Padding="18,16" Margin="5,0,5,0"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Tổng hội viên" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding TongHoiVien}" FontSize="28" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextDark}"/>
                                        <TextBlock Text=" người" FontSize="14" Foreground="{StaticResource TextMuted}" 
                                                   VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                    </StackPanel>
                                    <Border Background="#F0FDF4" CornerRadius="4" Padding="5,2" 
                                            Margin="0,6,0,0" HorizontalAlignment="Left">
                                        <TextBlock Text="Thành viên đã đăng ký" FontSize="11" Foreground="#16A34A"/>
                                    </Border>
                                </StackPanel>
                                <Border Width="44" Height="44" CornerRadius="10" Background="#F0FDF4"
                                        HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <fa:IconImage Icon="Users" Width="22" Height="22" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Card: Đặt sân hôm nay / tháng này -->
                        <Border Background="White" CornerRadius="12" Padding="18,16" Margin="5,0,5,0"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Lượt đặt sân" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding DatSanHomNay}" FontSize="28" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextDark}"/>
                                        <TextBlock Text=" hôm nay" FontSize="14" Foreground="{StaticResource TextMuted}" 
                                                   VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                                    </StackPanel>
                                    <Border Background="#FDF4FF" CornerRadius="4" Padding="5,2" 
                                            Margin="0,6,0,0" HorizontalAlignment="Left">
                                        <TextBlock FontSize="11" Foreground="#7C3AED">
                                            <Run Text="📅 Tháng này: "/>
                                            <Run Text="{Binding DatSanThangNay, Mode=OneWay}"/>
                                            <Run Text=" lượt"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <Border Width="44" Height="44" CornerRadius="10" Background="#FDF4FF"
                                        HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <fa:IconImage Icon="CalendarCheck" Width="22" Height="22" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Card: Doanh thu tháng -->
                        <Border Background="White" CornerRadius="12" Padding="18,16" Margin="10,0,0,0"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Doanh thu tháng" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding DoanhThuThangNay, StringFormat=N0}" 
                                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextDark}"/>
                                    </StackPanel>
                                    <Border Background="#FFF7ED" CornerRadius="4" Padding="5,2" 
                                            Margin="0,6,0,0" HorizontalAlignment="Left">
                                        <TextBlock FontSize="11" Foreground="#EA580C">
                                            <Run Text="💰 "/>
                                            <Run Text="{Binding ThangNamHienTai, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <Border Width="44" Height="44" CornerRadius="10" Background="#FFF7ED"
                                        HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <fa:IconImage Icon="Coins" Width="22" Height="22" Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </UniformGrid>

                    <!-- ═══════════ HÀNG 3: BIỂU ĐỒ 7 NGÀY ═══════════ -->
                    <Border Background="White" CornerRadius="12" Padding="20,16" 
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <fa:IconBlock Icon="ChartSimple" Foreground="{StaticResource TextDark}" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Lượt đặt sân 7 ngày gần nhất" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ThongKe7Ngay}" Height="180">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding SoLuong}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBlue}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                            <Border Width="36" Height="{Binding ChieuCaoBar}" CornerRadius="4,4,0,0"
                                                    Background="#3B82F6" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Thu}" FontSize="11" 
                                                       Foreground="{StaticResource TextMuted}"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding Ngay}" FontSize="10" 
                                                       Foreground="#94A3B8"
                                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
