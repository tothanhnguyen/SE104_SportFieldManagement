<Window
        x:Class="QuanLySan.Views.SuaSanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:models="clr-namespace:QuanLySan.Models"
        Title="Quản lí sân thể thao - Sửa"
        Width="750" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- ===== COLOR PALETTE ===== -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#222222"/>
        <SolidColorBrush x:Key="InputBorder" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="HintText" Color="#888888"/>

        <!-- ===== SIMPLE TEXTBOX STYLE ===== -->
        <Style x:Key="SimpleTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ===== SIMPLE COMBOBOX STYLE ===== -->
        <Style x:Key="SimpleComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ===== LABEL STYLE ===== -->
        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ===== SIMPLE BUTTON STYLE ===== -->
        <Style x:Key="SimpleButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>

        <!-- ===== DATAGRID STYLE ===== -->
        <Style x:Key="StyledDataGrid" TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="True"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="SelectionMode" Value="Extended"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#2A3E6A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <Border Background="White" ClipToBounds="True" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryBrush}"
                    Padding="20,12"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock Text="Tiếp nhận thông tin sân thể thao"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnThoat_Click"
                            Width="28" Height="28">
                        <fa:IconBlock Icon="Xmark" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,14,20,16">
                <StackPanel>

                    <!-- ── ROW 1: Mã sân | Tên sân ── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mã sân (giá trị phát sinh) -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}">
                                <Run Text="Mã sân"/>
                            </TextBlock>
                            <TextBox x:Name="txtMaSan" Text="{Binding MaSan}" Style="{StaticResource SimpleTextBox}" IsReadOnly="True" Background="#F0F0F0"/>
                        </StackPanel>

                        <!-- Tên sân -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tên sân" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtTenSan" Text="{Binding TenSan, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── ROW 2: Mã loại sân | Địa chỉ ── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mã loại sân -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mã loại sân" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cboMaLoaiSan" ItemsSource="{Binding DsLoaiSan}" SelectedItem="{Binding LoaiSanSelected, Mode=TwoWay}" Style="{StaticResource SimpleComboBox}"/>
                        </StackPanel>

                        <!-- Địa chỉ -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Địa chỉ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtDiaChi" Text="{Binding DiaChi}" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── ROW 3: Ghi chú | Tình trạng ── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Ghi chú -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtGhiChu" Text="{Binding GhiChu}" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>

                        <!-- Tình trạng -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tình trạng" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cboTinhTrang" ItemsSource="{Binding DsTinhTrang}" SelectedItem="{Binding TinhTrangSelected, Mode=TwoWay}" Style="{StaticResource SimpleComboBox}"/>
                        </StackPanel>
                    </Grid>


                    <!-- ══════════════════════════════════════════════ -->
                    <!-- ── GROUPBOX: Giờ sân - Nhập trực tiếp trong Grid ── -->
                    <!-- ══════════════════════════════════════════════ -->
                    <GroupBox Margin="0,4,0,16"
                              Padding="12,8,12,12"
                              BorderBrush="{StaticResource PrimaryBrush}"
                              BorderThickness="1.5">
                        <GroupBox.Header>
                            <TextBlock Text="  Giờ sân  "
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </GroupBox.Header>

                        <!-- ── DATAGRID: Nhập trực tiếp giờ sân ── -->
                        <DataGrid x:Name="dgGioSan"
                                  ItemsSource="{Binding DsGioSan}"
                                  Style="{StaticResource StyledDataGrid}"
                                  ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                                  Height="180"
                                  CanUserAddRows="False"
                                  CellEditEnding="DgGioSan_CellEditEnding">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Xóa khung giờ" 
                                                          Command="{Binding PlacementTarget.Tag.XoaGioCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBooked}" Value="True">
                                            <Setter Property="Background" Value="#E2E8F0"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="ToolTip" Value="Khung giờ này đã được đặt nên không thể thay đổi hay xóa."/>
                                        </DataTrigger>
                                        <Trigger Property="AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#F9F9F9"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Giờ bắt đầu" Binding="{Binding GioBatDau, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Giờ kết thúc" Binding="{Binding GioKetThuc, UpdateSourceTrigger=PropertyChanged}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                </DataGridTextColumn>

                                <!-- Loại ngày – ComboBox hiển thị trực tiếp -->
                                <DataGridTemplateColumn Header="Loại ngày" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{x:Static models:GioSanItem.DsLoaiNgay}"
                                                      SelectedItem="{Binding LoaiNgay, UpdateSourceTrigger=PropertyChanged}"
                                                      VerticalContentAlignment="Center"
                                                      Padding="4,0"
                                                      BorderThickness="0"
                                                      Background="Transparent"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Đơn giá – Tự động hiển thị, không cho sửa -->
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat=N0}" Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="4,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <!-- ══════════════════════════════════════════════ -->
                    <!-- ── NÚT XỬ LÝ ── -->
                    <!-- ══════════════════════════════════════════════ -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nút nghiệp vụ (bên trái) -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="btnThemSan" Content="Thêm" 
                                    Style="{StaticResource SimpleButton}"
                                    Background="{StaticResource PrimaryBrush}" 
                                    Foreground="White" FontWeight="Bold"
                                    Margin="0,0,10,0"
                                    Command="{Binding ThemGioCommand}"/>
                            <Button x:Name="btnLuu" Content="Lưu" 
                                    Style="{StaticResource SimpleButton}"
                                    Background="{StaticResource PrimaryBrush}" 
                                    Foreground="White" FontWeight="Bold"
                                    Command="{Binding LuuCommand}"/>
                        </StackPanel>

                        <!-- Nút hệ thống (bên phải) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnHuy" Content="Hủy" 
                                    Style="{StaticResource SimpleButton}" 
                                    Margin="0,0,10,0" 
                                    Command="{Binding HuyCommand}"/>
                            <Button x:Name="btnThoat" Content="Thoát" 
                                    Style="{StaticResource SimpleButton}"
                                    Click="BtnThoat_Click"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>

</Window>

