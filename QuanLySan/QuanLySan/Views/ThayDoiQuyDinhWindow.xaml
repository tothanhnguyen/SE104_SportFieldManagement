<Window
        x:Class="QuanLySan.Views.ThayDoiQuyDinhWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Thay đổi quy định"
        Width="800" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#222222"/>
        <SolidColorBrush x:Key="InputBorder" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="GridLineColor" Color="#E0E0E0"/>

        <Style x:Key="SimpleTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SimpleComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SimpleButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="35"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource SimpleButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CleanDataGridCell" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E2EAF8"/>
                    <Setter Property="Foreground" Value="#1B2A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CustomDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineColor}"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>
    </Window.Resources>

    <Border Background="White" ClipToBounds="True" CornerRadius="5" BorderBrush="{StaticResource InputBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,12" CornerRadius="4,4,0,0">
                <Grid>
                    <TextBlock Text="Thay đổi quy định" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnThoat_Click"
                            Width="28" Height="28">
                        <fa:IconBlock Icon="Xmark" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20,24,10">
                <StackPanel>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mức điểm mặc định" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtMucDiemMacDinh" Style="{StaticResource SimpleTextBox}" Text="{Binding MucDiemMacDinh, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Loại hội viên mặc định" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cbLoaiHoiVienMacDinh" 
                                      Style="{StaticResource SimpleComboBox}" 
                                      ItemsSource="{Binding DanhSachLoaiHoiVien}"
                                      DisplayMemberPath="TenHang"
                                      SelectedValuePath="MaLoaiHoiVien"
                                      SelectedValue="{Binding LoaiHoiVienMacDinh, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Hệ số tích điểm" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtHeSoTichDiem" Style="{StaticResource SimpleTextBox}" Text="{Binding SoTienQuyDoi, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Danh sách loại hội viên" Style="{StaticResource FieldLabel}" FontSize="14" Margin="0,0,0,10"/>

                    <DataGrid ItemsSource="{Binding DanhSachLoaiHoiVien}" SelectedItem="{Binding LoaiHoiVienSelected}" Style="{StaticResource CustomDataGrid}" CellStyle="{StaticResource CleanDataGridCell}" Height="180" Margin="0,0,0,0">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Xóa hạng này" Command="{Binding XoaCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}">
                                    <MenuItem.Icon>
                                        <fa:IconBlock Icon="Trash" Foreground="#FF4D4D"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>
                            <DataGridTextColumn Header="Loại hội viên" Binding="{Binding TenHang}" Width="*"/>
                            <DataGridTextColumn Header="Mức điểm tối thiểu" Binding="{Binding MucDiemToiThieu}" Width="*"/>
                            <DataGridTextColumn Header="Mức giảm giá" Binding="{Binding MucGiamGia}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="24,0,24,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Thêm" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" Command="{Binding ThemCommand}"/>
                    <Button Content="Thay đổi" Style="{StaticResource PrimaryButton}" Command="{Binding ThayDoiCommand}"/>
                </StackPanel>

                <Button Content="Thoát" Style="{StaticResource SimpleButton}" HorizontalAlignment="Right" Click="BtnThoat_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>
