<Window x:Class="QuanLySan.Views.TraCuuHoiVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLySan.Views"
        mc:Ignorable="d"
        Title="TraCuuHoiVien" Height="600" Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- ===== COLOR PALETTE ===== -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#222222"/>
        <SolidColorBrush x:Key="InputBorder" Color="#CCCCCC"/>

        <!-- ===== FIELD LABEL STYLE ===== -->
        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ===== PLACEHOLDER TEXTBOX STYLE ===== -->
        <Style x:Key="PlaceholderTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border x:Name="border"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3" SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false"
                                              VerticalAlignment="Center" Margin="2,0"/>
                            </Border>
                            <TextBlock x:Name="placeholder"
                                       Text="&lt;Có chứa&gt;"
                                       Foreground="#999999"
                                       Margin="8,0,0,0"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"
                                       FontStyle="Italic"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SIMPLE COMBOBOX STYLE ===== -->
        <Style x:Key="SimpleComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ===== SIMPLE BUTTON STYLE ===== -->
        <Style x:Key="SimpleButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== DATAGRID COLUMN HEADER STYLE ===== -->
        <Style x:Key="DataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#2A3E6A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <Border Background="#F5F5F5" CornerRadius="6" ClipToBounds="True"
            BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER BAR ===== -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}"
                    Padding="20,12" CornerRadius="5,5,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Tra cứu hội viên" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            FontSize="16" FontWeight="Bold" Foreground="White"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Width="28" Height="28"
                            Click="BtnThoat_Click"/>
                </Grid>
            </Border>

            <!-- ===== FILTER AREA ===== -->
            <StackPanel Grid.Row="1" Margin="20,15,20,10">

                <!-- ROW 1: Mã hội viên | Tên Hội Viên | SĐT | Email | Ghi chú | Giới tính | Tên loại hội viên -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Mã hội viên" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtMaHoiVien" Tag="MaHoiVien"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 TextChanged="OnSearchBoxTextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Tên Hội Viên" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtTenHoiVien" Tag="HoTen"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 TextChanged="OnSearchBoxTextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="SĐT" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtSDT" Tag="SDT"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 TextChanged="OnSearchBoxTextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtEmail" Tag="Email"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 TextChanged="OnSearchBoxTextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                        <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtGhiChu" Tag="GhiChu"
                                 Style="{StaticResource PlaceholderTextBox}"
                                 TextChanged="OnSearchBoxTextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="5" Margin="0,0,8,0">
                        <TextBlock Text="Giới tính" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cboGioiTinh" Style="{StaticResource SimpleComboBox}" SelectedIndex="0">
                            <ComboBoxItem>Tất cả</ComboBoxItem>
                            <ComboBoxItem>Nam</ComboBoxItem>
                            <ComboBoxItem>Nữ</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="6" Margin="0,0,0,0">
                        <TextBlock Text="Tên loại hội viên" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cboLoaiHoiVien" Style="{StaticResource SimpleComboBox}" SelectedIndex="0"/>
                    </StackPanel>
                </Grid>

                <!-- ROW 2: Điểm tích lũy | Ngày đăng ký | Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Điểm tích lũy từ ... đến ... -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Điểm tích lũy" VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontWeight="SemiBold" FontStyle="Italic"/>
                        <TextBlock Text="từ" Foreground="Red" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtDiemTu" Width="100" Height="28"
                                 VerticalContentAlignment="Center" Padding="6,4"
                                 BorderBrush="{StaticResource InputBorder}" BorderThickness="1"/>
                        <TextBlock Text="đến" Foreground="Red" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox x:Name="txtDiemDen" Width="100" Height="28"
                                 VerticalContentAlignment="Center" Padding="6,4"
                                 BorderBrush="{StaticResource InputBorder}" BorderThickness="1"/>
                    </StackPanel>

                    <!-- Ngày đăng ký từ ... đến ... -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                        <TextBlock Text="Ngày đăng ký" VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontWeight="SemiBold" FontStyle="Italic"/>
                        <TextBlock Text="từ" Foreground="Red" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtNgayTu" Width="100" Height="28"
                                 VerticalContentAlignment="Center" Padding="6,4"
                                 BorderBrush="{StaticResource InputBorder}" BorderThickness="1"/>
                        <TextBlock Text="đến" Foreground="Red" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox x:Name="txtNgayDen" Width="100" Height="28"
                                 VerticalContentAlignment="Center" Padding="6,4"
                                 BorderBrush="{StaticResource InputBorder}" BorderThickness="1"/>
                    </StackPanel>

                    <!-- Buttons: Tra cứu + Thoát -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnTimKiem" Content="Tra cứu"
                                Style="{StaticResource SimpleButton}"
                                Background="#2196F3" Foreground="White" FontWeight="Bold"
                                BorderThickness="0" MinWidth="90"
                                Click="BtnTimKiem_Click"/>
                        <Button x:Name="btnLamMoi" Content="Làm mới"
                                Style="{StaticResource SimpleButton}"
                                Background="#4CAF50" Foreground="White" FontWeight="Bold"
                                BorderThickness="0" Margin="10,0,0,0" MinWidth="80"
                                Click="BtnLamMoi_Click"/>
                        <Button x:Name="btnThoat" Content="Thoát"
                                Style="{StaticResource SimpleButton}"
                                Background="#F0F0F0" Foreground="#333"
                                Margin="10,0,0,0" MinWidth="80"
                                Click="BtnThoat_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ===== DATAGRID ===== -->
            <DataGrid x:Name="dgHoiVien" Grid.Row="2" Margin="20,5,20,20"
                      AutoGenerateColumns="False" Background="White"
                      IsReadOnly="True" CanUserAddRows="False"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#CCCCCC" VerticalGridLinesBrush="#CCCCCC"
                      RowHeight="35" ColumnHeaderHeight="32"
                      BorderBrush="{StaticResource InputBorder}" BorderThickness="1"
                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                      AlternatingRowBackground="#F9F9F9"
                      HeadersVisibility="Column">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT" Width="50" Binding="{Binding STT}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Mã Hội Viên" Width="*" Binding="{Binding MaHoiVien}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Tên Hội Viên" Width="1.5*" Binding="{Binding HoTen}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SĐT" Width="*" Binding="{Binding SDT}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Email" Width="1.5*" Binding="{Binding Email}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Mã Loại Hội Viên" Width="*" Binding="{Binding TenLoaiHoiVien}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Điểm Tích Lũy" Width="*" Binding="{Binding DiemTichLuy}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ngày Đăng Ký" Width="*" Binding="{Binding NgayDangKy, StringFormat=dd/MM/yyyy}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Giới Tính" Width="80" Binding="{Binding GioiTinh}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Ghi Chú" Width="*" Binding="{Binding GhiChu}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="6,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Popup gợi ý <có chứa> dùng chung cho các ô tìm kiếm dạng văn bản -->
            <Popup x:Name="popupGoiY" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border Background="White" BorderBrush="#888888" BorderThickness="1" CornerRadius="2">
                    <ListBox x:Name="lstGoiY" MaxHeight="180" MinWidth="150" BorderThickness="0"
                             SelectionChanged="LstGoiY_SelectionChanged"/>
                </Border>
            </Popup>
        </Grid>
    </Border>

</Window>
