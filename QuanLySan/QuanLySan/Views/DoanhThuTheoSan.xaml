<Window x:Class="QuanLySan.Views.DoanhThuTheoSan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLySan.Views"
        mc:Ignorable="d"
        Title="Báo cáo doanh thu theo sân" Height="500" Width="900"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <Style x:Key="DarkBlueButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1B2B49"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="#D1D1D1" 
                                BorderThickness="2" 
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,6"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#273C63"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightGrayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="#CCCCCC" 
                                BorderThickness="2" 
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="25,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E2E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#D1D1D1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B2B49" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <Grid Margin="20,0">
                    <TextBlock Text="Báo cáo doanh thu theo sân" 
                               Foreground="White" FontSize="18" 
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="24" Cursor="Hand" Click="Button_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <StackPanel Margin="0,0,50,0">
                        <TextBlock Text="Năm lập báo cáo" FontSize="16" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Width="200" Height="40">
                            <TextBlock Text="&lt;Năm hiện hành&gt;" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                        </Border>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Tháng lập báo cáo" FontSize="16" Margin="0,0,0,8"/>
                        <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Width="200" Height="40">
                            <TextBlock Text="&lt;Tháng hiện hành&gt;" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <Button Content="Báo cáo doanh thu" Style="{StaticResource DarkBlueButtonStyle}" Margin="0,0,20,0"/>
                    <Button Content="Thoát" Style="{StaticResource LightGrayButtonStyle}" MinWidth="120" Click="Button_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBlock Text="Tổng doanh số trong tháng của tất cả sân:" FontSize="16" VerticalAlignment="Center"/>
                    <Border Background="#8E8E8E" CornerRadius="5" Width="250" Height="35" Margin="20,0,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="3" Name="dgReport" 
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          Background="#EEEEEE" GridLinesVisibility="All"
                          HorizontalGridLinesBrush="Black" VerticalGridLinesBrush="Black"
                          BorderBrush="Black" BorderThickness="1"
                          HeadersVisibility="Column" RowHeight="45">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderBrush" Value="Black"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="16"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Tên Sân" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#8E8E8E" CornerRadius="10" Width="150" Height="20" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Doanh thu" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#8E8E8E" CornerRadius="10" Width="120" Height="20" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Tỷ lệ lấp đầy khung giờ" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#8E8E8E" CornerRadius="10" Width="200" Height="20" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Border>
</Window>