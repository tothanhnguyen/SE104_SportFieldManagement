<Window x:Class="QuanLySan.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Đổi Mật Khẩu" Height="450" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI">

    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="15" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="20,15" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconImage Icon="Key" Width="20" Height="20" Foreground="#3B82F6" Margin="0,0,10,0"/>
                        <TextBlock Text="Đổi Mật Khẩu" FontSize="18" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click">
                        <fa:IconBlock Icon="Xmark" FontSize="16" Foreground="#94A3B8"/>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="15" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#FEE2E2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Nội dung -->
            <StackPanel Grid.Row="1" Margin="24">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#EF4444" Margin="0,0,0,10" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Mật khẩu cũ -->
                <TextBlock Text="Mật khẩu hiện tại" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12,10" Margin="0,0,0,16">
                    <Grid>
                        <fa:IconBlock Icon="LockOpen" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <PasswordBox Margin="24,0,0,0" Background="Transparent" BorderThickness="0" Foreground="#1E293B" FontSize="14" PasswordChanged="PasswordBox_OldPasswordChanged"/>
                    </Grid>
                </Border>

                <!-- Mật khẩu mới -->
                <TextBlock Text="Mật khẩu mới" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12,10" Margin="0,0,0,16">
                    <Grid>
                        <fa:IconBlock Icon="Lock" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <PasswordBox Margin="24,0,0,0" Background="Transparent" BorderThickness="0" Foreground="#1E293B" FontSize="14" PasswordChanged="PasswordBox_NewPasswordChanged"/>
                    </Grid>
                </Border>

                <!-- Xác nhận mật khẩu mới -->
                <TextBlock Text="Xác nhận mật khẩu mới" Foreground="#475569" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Background="#F8FAFC" Padding="12,10" Margin="0,0,0,16">
                    <Grid>
                        <fa:IconBlock Icon="CheckDouble" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <PasswordBox Margin="24,0,0,0" Background="Transparent" BorderThickness="0" Foreground="#1E293B" FontSize="14" PasswordChanged="PasswordBox_ConfirmNewPasswordChanged"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="20" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Width="80" Height="36" Background="White" Foreground="#475569" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,12,0" Cursor="Hand" Click="CloseButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Lưu thay đổi" Width="120" Height="36" Background="#3B82F6" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Command="{Binding SubmitCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="6" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
