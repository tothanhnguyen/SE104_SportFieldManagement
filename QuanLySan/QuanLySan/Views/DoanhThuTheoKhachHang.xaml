<Window x:Class="QuanLySan.Views.DoanhThuTheoKhachHang"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLySan.Views"
        mc:Ignorable="d"
        Title="DoanhThuTheoKhachHang" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" WindowStartupLocation="CenterScreen">

    <Border Background="#D1D1D1" CornerRadius="0" BorderBrush="Black" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B2B49">
                <Grid Margin="20,0">
                    <TextBlock Text="Báo cáo doanh thu theo sân" 
                               Foreground="White" FontSize="18" 
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="24" Cursor="Hand" Click="Button_Click_1"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
                    <StackPanel Margin="0,0,50,0">
                        <TextBlock Text="Năm lập báo cáo" FontSize="16" Margin="0,0,0,8" Foreground="Black"/>
                        <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Width="200" Height="40">
                            <TextBlock Text="&lt;Năm hiện hành&gt;" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                        </Border>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Tháng lập báo cáo" FontSize="16" Margin="0,0,0,8" Foreground="Black"/>
                        <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1" CornerRadius="5" Width="200" Height="40">
                            <TextBlock Text="&lt;Tháng hiện hành&gt;" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBlock Text="Tổng doanh số trong tháng của tất cả sân:" FontSize="16" VerticalAlignment="Center" Foreground="Black"/>
                    <Border Background="#8E8E8E" CornerRadius="5" Width="250" Height="35" Margin="20,0,0,0"/>
                </StackPanel>

                <DataGrid Grid.Row="2" Name="dgReport" 
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          Background="#FFF5F5" GridLinesVisibility="All"
                          HorizontalGridLinesBrush="Black" VerticalGridLinesBrush="Black"
                          BorderBrush="Black" BorderThickness="1"
                          HeadersVisibility="Column" RowHeight="45">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderBrush" Value="Black"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="16"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="15"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Tên Sân" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#8E8E8E" CornerRadius="10" Width="150" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Doanh thu" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#8E8E8E" CornerRadius="10" Width="120" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Tỷ lệ lấp đầy khung giờ" Width="3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#8E8E8E" CornerRadius="10" Width="200" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Border>
</Window>

