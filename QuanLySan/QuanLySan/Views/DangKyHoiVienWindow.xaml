<Window 
    x:Class="QuanLySan.Views.DangKyHoiVienWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Đăng ký hội viên" 
    Width="700"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="Transparent"
    FontFamily="Segoe UI"
    FontSize="13"
    WindowStyle="None"
    AllowsTransparency="True">


    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#222222"/>
        <SolidColorBrush x:Key="InputBorder" Color="#CCCCCC"/>

        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SimpleTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SimpleComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SimpleButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>

        <Style x:Key="PlaceholderDatePicker" TargetType="{x:Type DatePicker}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                <Grid>
                                    <Border x:Name="BaseBorder" Background="Transparent"/>
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="2,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextPrompt" 
                                       Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=DatePicker}}" 
                                       Foreground="Gray" 
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Margin="5,0,0,0" 
                                       Visibility="Collapsed"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                        <Setter TargetName="TextPrompt" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="PlaceholderTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource SimpleTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border x:Name="border" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="{TemplateBinding Background}" 
                                SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="placeholder" 
                                   Text="{TemplateBinding Tag}" 
                                   Foreground="#888888" 
                                   Margin="7,0,0,0" 
                                   IsHitTestVisible="False" 
                                   VerticalAlignment="Center" 
                                   Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" ClipToBounds="True" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER BAR ===== -->
            <Border Grid.Row="0" 
                    Background="{StaticResource PrimaryBrush}" 
                    Padding="20,12" 
                    MouseLeftButtonDown="Header_MouseLeftButtonDown"
                    CornerRadius="5,5,0,0">
                <Grid>
                    <TextBlock Text="Đăng ký hội viên" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            FontSize="16" FontWeight="Bold" 
                            Foreground="White" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Click="BtnThoat_Click" 
                            Width="28" Height="28"/>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,20,20,16">
                <StackPanel>

                    <!-- ROW 1: Mã hội viên | Tên hội viên -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mã hội viên" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MaHoiVien}" 
                                     Style="{StaticResource PlaceholderTextBox}" 
                                     Tag="&lt; Giá trị phát sinh &gt;"
                                     IsReadOnly="True" 
                                     Background="#EFEFEF" 
                                     Foreground="#555"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Họ tên hội viên" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding TenHoiVien, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ROW 2: SĐT | Email -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Số điện thoại" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SDT}" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Email}" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ROW 3: Ngày đăng ký | Giới tính | Loại hội viên | Điểm tích lũy -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ngày đăng ký" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding ngaydangky}" 
                                        Style="{StaticResource PlaceholderDatePicker}" 
                                        Tag="&lt;Ngày hiện hành&gt;"
                                        IsHitTestVisible="False" 
                                        Focusable="False"
                                        Background="#F9F9F9"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giới tính" Style="{StaticResource FieldLabel}"/>
                            <ComboBox SelectedItem="{Binding GioiTinhSelected}" Style="{StaticResource SimpleComboBox}">
                                <ComboBoxItem Content="Nam"/>
                                <ComboBoxItem Content="Nữ"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Loại hội viên" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="Đồng" 
                                     Style="{StaticResource SimpleTextBox}" 
                                     IsReadOnly="True" 
                                     Background="#EFEFEF"/>
                        </StackPanel>
                    </Grid>

                    <!-- ROW 4: Ghi chú -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding GhiChu}" Style="{StaticResource SimpleTextBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="6"/>
                    </StackPanel>

                    <!-- BUTTONS -->
                    <Grid>
                        <!-- Nút Đăng ký, Làm mới -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Làm mới" Style="{StaticResource SimpleButton}" Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold" Margin="0,0,10,0" Command="{Binding ThemCommand}"/>
                            <Button Content="Đăng ký" Style="{StaticResource SimpleButton}" Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold" Command="{Binding LuuCommand}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>