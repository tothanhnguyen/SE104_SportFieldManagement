<Window x:Class="QuanLySan.Views.DangKyHoiVienWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        Title="Đăng ký hội viên" 
        Width="800"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#222222"/>
        <SolidColorBrush x:Key="InputBorder" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#D32F2F"/>

        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SimpleTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="PlaceholderTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource SimpleTextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="4" SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="placeholder" 
                                       Text="{TemplateBinding Tag}" 
                                       Foreground="#888888" 
                                       Margin="10,0,0,0" 
                                       IsHitTestVisible="False" 
                                       VerticalAlignment="Center" 
                                       Visibility="Collapsed"
                                       FontStyle="Italic"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="#F2F2F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaceholderDatePicker" TargetType="{x:Type DatePicker}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="{x:Type DatePickerTextBox}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                <Grid>
                                    <Border Background="Transparent"/>
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="2,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TextPrompt" 
                                               Text="{Binding Tag, RelativeSource={RelativeSource AncestorType=DatePicker}}" 
                                               Foreground="Gray" IsHitTestVisible="False" VerticalAlignment="Center" 
                                               Margin="5,0,0,0" Visibility="Collapsed" FontStyle="Italic"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                        <Setter TargetName="TextPrompt" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SimpleComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SimpleButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="35"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#F5F5F5" CornerRadius="8" ClipToBounds="True" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,15" CornerRadius="7,7,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="ĐĂNG KÝ HỘI VIÊN MỚI" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnThoat_Click">
                        <fa:IconBlock Icon="Xmark" FontSize="18" FontWeight="Bold"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mã hội viên" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding MaHoiVien}" Style="{StaticResource PlaceholderTextBox}" 
                                     Tag="&lt; Giá trị phát sinh &gt;" IsReadOnly="True" Background="#EFEFEF" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Họ tên hội viên" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding TenHoiVien}" Style="{StaticResource PlaceholderTextBox}" 
                                     Tag="VD: Nguyễn Văn A"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Số điện thoại" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SDT}" Style="{StaticResource PlaceholderTextBox}" Tag="0000.000.000"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Email}" Style="{StaticResource PlaceholderTextBox}" Tag="VD: nva@gmail.com"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ngày đăng ký" Style="{StaticResource FieldLabel}"/>
                            <DatePicker SelectedDate="{Binding NgayDangKy}" Style="{StaticResource PlaceholderDatePicker}" 
                                        Tag="&lt; Ngày hiện hành &gt;" IsHitTestVisible="False" Focusable="False"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giới tính" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Style="{StaticResource SimpleComboBox}"
                                     SelectedValue="{Binding GioiTinh, Mode=TwoWay}"
                                     SelectedValuePath="Content">
                                <ComboBoxItem Content="Nam" IsSelected="True"/>
                                <ComboBoxItem Content="Nữ"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Loại hội viên" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="Đồng" Style="{StaticResource SimpleTextBox}" IsReadOnly="True" Background="#EFEFEF"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SimpleTextBox}" Height="70" VerticalContentAlignment="Top" 
                                 TextWrapping="Wrap" AcceptsReturn="True" Padding="8"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,25">
                        <Button Content="THOÁT" 
                        Style="{StaticResource SimpleButton}" 
                        Background="#E0E0E0" 
                        Foreground="#333" 
                        HorizontalAlignment="Left"
                        Click="BtnThoat_Click"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="LÀM MỚI" 
                            Style="{StaticResource SimpleButton}" 
                            Background="#E0E0E0" 
                            Foreground="#333" 
                            Margin="0,0,10,0"
                            Command="{Binding LamMoiCommand}"/>

                            <Button Content="ĐĂNG KÝ" 
                            Style="{StaticResource SimpleButton}" 
                            Background="{StaticResource PrimaryBrush}" 
                            Foreground="White" 
                            FontWeight="Bold"
                            Command="{Binding DangKyCommand}"/> 
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>